{
  "type": "page",
  "title": "角色管理",
  "body": [
    {
      "type": "crud",
      "api": {
        "method": "get",
        "url": "/api/roles",
        "data": {
          "pageNo": "${page}",
          "pageSize": "${perPage}",
          "keyword": "${keyword}"
        },
        "adaptor": "if(payload.code!==0)return {status:payload.code,msg:payload.message}; return {status:0,data:{items:payload.data.items||[],total:payload.data.total||0}};"
      },
      "headerToolbar": [
        {
          "type": "input-text",
          "name": "keyword",
          "placeholder": "搜索角色",
          "clearable": true,
          "addOn": {
            "type": "submit",
            "label": "搜索",
            "level": "primary"
          }
        },
        {
          "type": "button",
          "label": "新增角色",
          "level": "primary",
          "visibleOn": "this.__perms && this.__perms.indexOf('role:create')>=0",
          "actionType": "dialog",
          "dialog": {
            "title": "新增角色",
            "size": "md",
            "body": {
              "type": "form",
              "api": {
                "method": "post",
                "url": "/api/roles"
              },
              "body": [
                {
                  "type": "input-text",
                  "name": "name",
                  "label": "名称",
                  "required": true
                },
                {
                  "type": "input-text",
                  "name": "code",
                  "label": "编码"
                },
                {
                  "type": "textarea",
                  "name": "remark",
                  "label": "备注"
                }
              ]
            }
          }
        },
        "pagination"
      ],
      "columns": [
        {
          "name": "name",
          "label": "名称"
        },
        {
          "name": "code",
          "label": "编码"
        },
        {
          "name": "remark",
          "label": "备注"
        },
        {
          "type": "operation",
          "label": "操作",
          "buttons": [
            {
              "type": "button",
              "label": "授权",
              "visibleOn": "this.__perms && this.__perms.indexOf('role:perm:write')>=0",
              "actionType": "drawer",
              "drawer": {
                "title": "角色授权",
                "size": "lg",
                "body": {
                  "$ref": "/schemas/rbac/role-permissions.json"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}