{
  "type": "service",
  "api": {
    "method": "get",
    "url": "/api/roles/${id}/permissions",
    "adaptor": "if(payload.code!==0)return {status:payload.code,msg:payload.message}; return {status:0,data:{rolePerms:payload.data||[]}};"
  },
  "body": [
    {
      "type": "form",
      "wrapWithPanel": false,
      "body": [
        {
          "type": "transfer",
          "name": "permissions",
          "label": "权限点",
          "searchable": true,
          "source": {
            "method": "get",
            "url": "/assets/permissions-tree.json"
          },
          "value": "${rolePerms}"
        }
      ],
      "api": {
        "method": "put",
        "url": "/api/roles/${id}/permissions",
        "data": {
          "permissions": "${permissions}"
        }
      }
    }
  ]
}