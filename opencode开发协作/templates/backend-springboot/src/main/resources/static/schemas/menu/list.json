{
  "type": "page",
  "title": "菜单管理（Demo）",
  "body": [
    {
      "type": "service",
      "api": {
        "method": "get",
        "url": "/api/menus/tree?scene=ADMIN",
        "adaptor": "if(payload.code!==0)return {status:payload.code,msg:payload.message}; return {status:0,data:{items:payload.data||[]}};"
      },
      "body": [
        {
          "type": "tree",
          "source": "${items}",
          "labelField": "title",
          "valueField": "id",
          "itemActions": [
            {
              "type": "button",
              "label": "动作开关",
              "size": "sm",
              "actionType": "drawer",
              "drawer": {
                "title": "菜单动作配置",
                "size": "lg",
                "body": {
                  "$ref": "/schemas/menu/bind-actions.json"
                }
              }
            },
            {
              "type": "button",
              "label": "字段策略",
              "size": "sm",
              "actionType": "drawer",
              "drawer": {
                "title": "字段策略",
                "size": "xl",
                "body": {
                  "$ref": "/schemas/menu/bind-field-policies.json"
                }
              }
            },
            {
              "type": "button",
              "label": "动作策略",
              "size": "sm",
              "actionType": "drawer",
              "drawer": {
                "title": "动作条件策略",
                "size": "xl",
                "body": {
                  "$ref": "/schemas/menu/bind-action-policies.json"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}