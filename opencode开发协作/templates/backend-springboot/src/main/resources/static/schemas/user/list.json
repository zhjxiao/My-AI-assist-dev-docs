{
  "type": "page",
  "title": "用户管理",
  "body": [
    {
      "type": "crud",
      "api": {
        "method": "get",
        "url": "/api/users",
        "data": {
          "pageNo": "${page}",
          "pageSize": "${perPage}",
          "keyword": "${keyword}",
          "menuId": "${__menuId}"
        },
        "adaptor": "if(!payload)return {status:500,msg:'EMPTY'}; if(payload.code!==0)return {status:payload.code||500,msg:payload.message||'ERROR'}; return {status:0,data:{items:payload.data.items||[],total:payload.data.total||0}};"
      },
      "headerToolbar": [
        {
          "type": "input-text",
          "name": "keyword",
          "placeholder": "搜索登录名/姓名",
          "clearable": true,
          "addOn": {
            "type": "submit",
            "label": "搜索",
            "level": "primary"
          }
        },
        {
          "type": "button",
          "label": "新增用户",
          "level": "primary",
          "visibleOn": "(this.__perms && this.__perms.indexOf('user:create')>=0) && (this.__menuActions && this.__menuActions.indexOf('user:create')>=0) && AP_VISIBLE('user','user:create','TOOLBAR')",
          "disabledOn": "AP_DISABLED('user','user:create','TOOLBAR')",
          "actionType": "dialog",
          "dialog": {
            "title": "新增用户",
            "size": "lg",
            "body": {
              "type": "form",
              "data": {
                "__mode": "create"
              },
              "api": {
                "method": "post",
                "url": "/api/users"
              },
              "body": {
                "$ref": "/schemas/user/_form.json"
              }
            }
          }
        },
        "pagination"
      ],
      "columns": [
        {
          "name": "username",
          "label": "登录名",
          "visibleOn": "FP_VISIBLE('user','username','LIST')"
        },
        {
          "name": "realName",
          "label": "姓名",
          "visibleOn": "FP_VISIBLE('user','realName','LIST')"
        },
        {
          "name": "orgId",
          "label": "组织",
          "visibleOn": "FP_VISIBLE('user','orgId','LIST')"
        },
        {
          "name": "status",
          "label": "状态",
          "visibleOn": "FP_VISIBLE('user','status','LIST')"
        },
        {
          "type": "tpl",
          "name": "phone",
          "label": "手机号",
          "visibleOn": "FP_VISIBLE('user','phone','LIST')",
          "tpl": "${FP_MASK('user','phone','LIST') ? MASK(phone,'phone') : phone}"
        },
        {
          "name": "createdAt",
          "label": "创建时间",
          "type": "date",
          "format": "YYYY-MM-DD HH:mm:ss",
          "visibleOn": "FP_VISIBLE('user','createdAt','LIST')"
        },
        {
          "type": "operation",
          "label": "操作",
          "buttons": [
            {
              "type": "button",
              "label": "编辑",
              "visibleOn": "(this.__perms && this.__perms.indexOf('user:update')>=0) && (this.__menuActions && this.__menuActions.indexOf('user:update')>=0) && AP_VISIBLE('user','user:update','ROW')",
              "disabledOn": "AP_DISABLED('user','user:update','ROW')",
              "actionType": "dialog",
              "dialog": {
                "title": "编辑用户",
                "size": "lg",
                "body": {
                  "type": "form",
                  "data": {
                    "__mode": "edit"
                  },
                  "initApi": {
                    "method": "get",
                    "url": "/api/users/${id}"
                  },
                  "api": {
                    "method": "put",
                    "url": "/api/users/${id}"
                  },
                  "body": {
                    "$ref": "/schemas/user/_form.json"
                  }
                }
              }
            },
            {
              "type": "button",
              "label": "删除",
              "level": "danger",
              "visibleOn": "(this.__perms && this.__perms.indexOf('user:delete')>=0) && (this.__menuActions && this.__menuActions.indexOf('user:delete')>=0) && AP_VISIBLE('user','user:delete','ROW')",
              "disabledOn": "AP_DISABLED('user','user:delete','ROW')",
              "confirmText": "${AP_META('user','user:delete','ROW').confirmText || '确定删除该用户？'}",
              "actionType": "ajax",
              "api": {
                "method": "delete",
                "url": "/api/users/${id}"
              }
            },
            {
              "type": "button",
              "label": "分配角色",
              "visibleOn": "(this.__perms && this.__perms.indexOf('user:role:write')>=0) && (this.__menuActions && this.__menuActions.indexOf('user:role:write')>=0) && AP_VISIBLE('user','user:role:write','ROW')",
              "disabledOn": "AP_DISABLED('user','user:role:write','ROW')",
              "actionType": "drawer",
              "drawer": {
                "title": "分配角色",
                "size": "lg",
                "body": {
                  "$ref": "/schemas/user/assign-roles.json"
                }
              }
            }
          ]
        }
      ]
    }
  ]
}