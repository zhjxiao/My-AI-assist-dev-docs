[
  {
    "type": "input-text",
    "name": "username",
    "label": "登录名",
    "required": true,
    "visibleOn": "this.__mode!=='edit'"
  },
  {
    "type": "static",
    "name": "username",
    "label": "登录名",
    "visibleOn": "this.__mode==='edit'"
  },
  {
    "type": "input-text",
    "name": "realName",
    "label": "姓名",
    "required": true,
    "visibleOn": "FP_VISIBLE('user','realName','FORM')",
    "disabledOn": "FP_READONLY('user','realName','FORM')"
  },
  {
    "type": "input-text",
    "name": "orgId",
    "label": "组织",
    "required": true,
    "visibleOn": "FP_VISIBLE('user','orgId','FORM')",
    "disabledOn": "FP_READONLY('user','orgId','FORM')"
  },
  {
    "type": "select",
    "name": "status",
    "label": "状态",
    "required": true,
    "options": [
      {
        "label": "启用",
        "value": "ENABLED"
      },
      {
        "label": "禁用",
        "value": "DISABLED"
      }
    ],
    "visibleOn": "FP_VISIBLE('user','status','FORM')",
    "disabledOn": "FP_READONLY('user','status','FORM')"
  },
  {
    "type": "input-text",
    "name": "phone",
    "label": "手机号",
    "visibleOn": "FP_VISIBLE('user','phone','FORM')",
    "disabledOn": "FP_READONLY('user','phone','FORM')"
  }
]