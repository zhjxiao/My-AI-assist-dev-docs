{
  "type": "page",
  "title": "菜单管理",
  "data": {
    "__perms": "${__perms}"
  },
  "body": [
    {
      "type": "service",
      "api": {
        "method": "get",
        "url": "/api/menus/tree?scene=ADMIN",
        "adaptor": "if(!payload)return {status:500,msg:'EMPTY'}; if(payload.code!==0)return {status:payload.code||500,msg:payload.message||'ERROR'}; return {status:0,data:{items:payload.data||[]}};"
      },
      "body": [
        {
          "type": "button",
          "label": "新建菜单",
          "level": "primary",
          "visibleOn": "this.__perms && this.__perms.indexOf('menu:create')>=0",
          "actionType": "dialog",
          "dialog": {
            "title": "新建菜单",
            "size": "lg",
            "body": {
              "type": "form",
              "api": {
                "method": "post",
                "url": "/api/menus"
              },
              "body": {
                "$ref": "/schemas/menu/_form.json"
              }
            }
          }
        },
        {
          "type": "divider"
        },
        {
          "type": "tree",
          "source": "${items}",
          "labelField": "title",
          "valueField": "id",
          "showIcon": false,
          "itemActions": [
            {
              "type": "button",
              "label": "编辑",
              "size": "sm",
              "visibleOn": "this.__perms && this.__perms.indexOf('menu:update')>=0",
              "actionType": "dialog",
              "dialog": {
                "title": "编辑菜单",
                "size": "lg",
                "body": {
                  "type": "form",
                  "initApi": {
                    "method": "get",
                    "url": "/api/menus/${id}"
                  },
                  "api": {
                    "method": "put",
                    "url": "/api/menus/${id}"
                  },
                  "body": {
                    "$ref": "/schemas/menu/_form.json"
                  }
                }
              }
            },
            {
              "type": "button",
              "label": "权限绑定",
              "size": "sm",
              "visibleOn": "this.__perms && this.__perms.indexOf('menu:perm:write')>=0",
              "actionType": "drawer",
              "drawer": {
                "title": "菜单权限绑定",
                "size": "lg",
                "body": {
                  "$ref": "/schemas/menu/bind-permissions.json"
                }
              }
            },
            {
              "type": "button",
              "label": "动作开关",
              "size": "sm",
              "visibleOn": "this.__perms && this.__perms.indexOf('menu:action:write')>=0",
              "actionType": "drawer",
              "drawer": {
                "title": "菜单动作配置",
                "size": "lg",
                "body": {
                  "$ref": "/schemas/menu/bind-actions.json"
                }
              }
            },
            {
              "type": "button",
              "label": "字段策略",
              "size": "sm",
              "visibleOn": "this.__perms && this.__perms.indexOf('menu:field:write')>=0",
              "actionType": "drawer",
              "drawer": {
                "title": "字段策略",
                "size": "xl",
                "body": {
                  "$ref": "/schemas/menu/bind-field-policies.json"
                }
              }
            },
            {
              "type": "button",
              "label": "动作策略",
              "size": "sm",
              "visibleOn": "this.__perms && this.__perms.indexOf('menu:actionPolicy:write')>=0",
              "actionType": "drawer",
              "drawer": {
                "title": "动作条件策略",
                "size": "xl",
                "body": {
                  "$ref": "/schemas/menu/bind-action-policies.json"
                }
              }
            },
            {
              "type": "button",
              "label": "数据范围",
              "size": "sm",
              "visibleOn": "this.__perms && this.__perms.indexOf('menu:scope:write')>=0",
              "actionType": "drawer",
              "drawer": {
                "title": "菜单数据范围策略",
                "size": "lg",
                "body": {
                  "$ref": "/schemas/menu/bind-data-scope.json"
                }
              }
            },
            {
              "type": "button",
              "label": "删除",
              "size": "sm",
              "level": "danger",
              "visibleOn": "this.__perms && this.__perms.indexOf('menu:delete')>=0",
              "actionType": "ajax",
              "confirmText": "确定删除该菜单及其子菜单？",
              "api": {
                "method": "delete",
                "url": "/api/menus/${id}"
              }
            }
          ]
        }
      ]
    }
  ]
}