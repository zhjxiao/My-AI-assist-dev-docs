{
  "type": "page",
  "title": "灰度规则",
  "data": { "__perms": "${__perms}" },
  "body": [
    {
      "type": "crud",
      "name": "canaryCrud",
      "syncLocation": false,
      "api": { "method": "get", "url": "/api/menus/${menuId}/config/canary-rules" },
      "headerToolbar": [
        {
          "type": "button",
          "label": "新增规则",
          "level": "primary",
          "visibleOn": "this.__perms && this.__perms.indexOf('menu:config:canary:create')>=0",
          "actionType": "dialog",
          "dialog": {
            "title": "新增灰度规则",
            "size": "lg",
            "body": {
              "type": "form",
              "api": { "method": "post", "url": "/api/menus/${menuId}/config/canary-rules" },
              "body": [
                { "type": "switch", "name": "enabled", "label": "启用", "value": true },
                { "type": "input-text", "name": "versionId", "label": "命中版本ID", "required": true },
                {
                  "type": "select",
                  "name": "matchType",
                  "label": "匹配方式",
                  "required": true,
                  "options": [
                    { "label": "百分比", "value": "PERCENT" },
                    { "label": "用户ID列表", "value": "USER_IDS" },
                    { "label": "角色ID列表", "value": "ROLE_IDS" },
                    { "label": "组织ID列表", "value": "ORG_IDS" },
                    { "label": "用户组ID列表", "value": "GROUP_IDS" }
                  ]
                },
                { "type": "input-number", "name": "percent", "label": "百分比", "visibleOn": "this.matchType==='PERCENT'" },
                { "type": "textarea", "name": "userIds", "label": "用户ID列表(逗号分隔)", "visibleOn": "this.matchType==='USER_IDS'" },
                { "type": "textarea", "name": "roleIds", "label": "角色ID列表(逗号分隔)", "visibleOn": "this.matchType==='ROLE_IDS'" },
                { "type": "textarea", "name": "orgIds", "label": "组织ID列表(逗号分隔)", "visibleOn": "this.matchType==='ORG_IDS'" },
                { "type": "textarea", "name": "groupIds", "label": "用户组ID列表(逗号分隔)", "visibleOn": "this.matchType==='GROUP_IDS'" },
                { "type": "input-datetime", "name": "startAt", "label": "开始时间" },
                { "type": "input-datetime", "name": "endAt", "label": "结束时间" },
                { "type": "textarea", "name": "note", "label": "说明" }
              ],
              "data": { "enabled": true }
            }
          }
        }
      ],
      "columns": [
        { "name": "id", "label": "规则ID" },
        { "name": "enabled", "label": "启用", "type": "switch" },
        { "name": "versionId", "label": "命中版本" },
        { "name": "matchType", "label": "匹配方式" },
        { "name": "percent", "label": "百分比" },
        { "name": "startAt", "label": "开始", "type": "date", "format": "YYYY-MM-DD HH:mm:ss" },
        { "name": "endAt", "label": "结束", "type": "date", "format": "YYYY-MM-DD HH:mm:ss" },
        { "name": "note", "label": "说明" },
        {
          "type": "operation",
          "label": "操作",
          "buttons": [
            {
              "type": "button",
              "label": "删除",
              "level": "danger",
              "visibleOn": "this.__perms && this.__perms.indexOf('menu:config:canary:delete')>=0",
              "actionType": "ajax",
              "confirmText": "确定删除该灰度规则？",
              "api": { "method": "delete", "url": "/api/menus/${menuId}/config/canary-rules/${id}" }
            }
          ]
        }
      ]
    }
  ]
}